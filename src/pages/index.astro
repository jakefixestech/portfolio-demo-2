---
// The White Birch - Luxury NH Wedding Venue
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="The White Birch - A luxury wedding venue in Littleton, New Hampshire. Where forever begins." />
  <title>The White Birch | Luxury Wedding Venue</title>

  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=optional" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=optional" /></noscript>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      background-color: #faf8f5;
      color: #1a1714;
      -webkit-font-smoothing: antialiased;
    }

    .font-display { font-family: 'Cormorant Garamond', Georgia, serif; }

    .reveal-card {
      opacity: 0;
      transform: translateY(60px);
      transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    }
    .reveal-card.is-visible { opacity: 1; transform: translateY(0); }

    .hero-vignette::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.25) 100%);
      pointer-events: none;
    }

    .card-inner {
      display: flex;
      flex-direction: column;
    }

    .card-img {
      width: 100%;
      height: 18rem;
      object-fit: cover;
      flex-shrink: 0;
    }

    .card-text {
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .gold-rule {
      width: 3rem;
      height: 1px;
      background-color: #c9a96e;
      margin-bottom: 1.25rem;
    }

    nav a, footer a { text-decoration: none; }
    nav a:hover, footer a:hover { text-decoration: underline; }

    @media (min-width: 768px) {
      .card-inner { flex-direction: row; height: 26rem; }
      .card-inner.reverse { flex-direction: row-reverse; }
      .card-img { width: 45%; height: 100%; }
      .card-text { width: 55%; padding: 3rem 3.5rem; }

      .footer-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 2rem;
      }
    }
  </style>
</head>

<body>

  <!-- Fixed Navigation -->
  <nav style="position:fixed;top:0;left:0;right:0;z-index:100;padding:1.25rem 4rem;background:linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, transparent 100%);" aria-label="Main navigation">
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <a href="#" class="font-display" style="font-size:1.2rem;color:#ffffff;letter-spacing:0.05em;font-style:italic;">
        The White Birch
      </a>
      <div style="display:flex;align-items:center;gap:2.5rem;">
        <a href="#" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.2em;color:#ffffff;">Venue</a>
        <a href="#" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.2em;color:#ffffff;">Weddings</a>
        <a href="#" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.2em;color:#ffffff;">Contact</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section style="position:relative;height:100vh;width:100%;overflow:hidden;" class="hero-vignette">
    <img
      src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=1600"
      alt="Beautiful outdoor wedding venue with long floral table and warm lighting"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
    />
    <!-- Dark overlay for text readability -->
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);z-index:1;"></div>
    <div style="position:relative;z-index:10;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:1.5rem;text-align:center;">
      <div style="background:rgba(0,0,0,0.35);padding:3rem 4rem;border-radius:0.5rem;backdrop-filter:blur(2px);">
      <h1 style="display:flex;flex-direction:column;align-items:center;">
        <span class="font-display" style="font-style:italic;font-size:clamp(3rem,8vw,6rem);color:#ffffff;line-height:1.1;">
          Where forever
        </span>
        <span class="font-display" style="font-size:clamp(3.5rem,10vw,7.5rem);color:#ffffff;font-weight:600;letter-spacing:-0.02em;line-height:1;margin-top:0.25rem;">
          begins.
        </span>
      </h1>
      <div style="width:5rem;height:1px;background-color:#c9a96e;margin:2rem 0 1.5rem;"></div>
      <p style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.25em;color:#ffffff;">
        Littleton, New Hampshire · Est. 2018
      </p>
      <a href="#" style="margin-top:2.5rem;font-size:0.875rem;color:#ffffff;display:inline-flex;align-items:center;gap:0.5rem;">
        Explore the venue →
      </a>
      </div>
    </div>
  </section>

  <!-- Section 1: The Ceremony (Dark) -->
  <section style="background-color:#1a1714;padding:6rem 1.5rem;" aria-labelledby="ceremony-heading">
    <div class="reveal-card" style="max-width:64rem;margin:0 auto;background-color:#242019;border-radius:1rem;overflow:hidden;box-shadow:0 25px 50px rgba(0,0,0,0.4);">
      <div class="card-inner">
        <img class="card-img"
          src="https://images.unsplash.com/photo-1606800052052-a08af7148866?w=800"
          alt="Gold wedding rings on elegant linen for the ceremony"
        />
        <div class="card-text">
          <p style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.3em;color:#d4a853;margin-bottom:1rem;">01 · Ceremony</p>
          <h2 id="ceremony-heading" class="font-display" style="font-style:italic;font-size:clamp(1.75rem,3vw,2.75rem);color:#ffffff;line-height:1.2;margin-bottom:1rem;">
            A moment that takes your breath away
          </h2>
          <div class="gold-rule"></div>
          <p style="font-size:0.875rem;color:#c8bdb6;line-height:1.8;">
            Our sun-dappled birch grove creates an ethereal backdrop for your vows, where nature becomes witness to your forever promise.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: The Reception (Light) -->
  <section style="background-color:#faf8f5;padding:6rem 1.5rem;" aria-labelledby="reception-heading">
    <div class="reveal-card" style="max-width:64rem;margin:0 auto;background-color:#ffffff;border-radius:1rem;overflow:hidden;box-shadow:0 25px 50px rgba(0,0,0,0.08);">
      <div class="card-inner reverse">
        <img class="card-img"
          src="https://images.unsplash.com/photo-1464366400600-7168b8af9bc3?w=800"
          alt="Elegant wedding reception table with floral centerpieces and candlelight"
        />
        <div class="card-text">
          <p style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.3em;color:#8a6d3b;margin-bottom:1rem;">02 · Reception</p>
          <h2 id="reception-heading" class="font-display" style="font-style:italic;font-size:clamp(1.75rem,3vw,2.75rem);color:#1a1714;line-height:1.2;margin-bottom:1rem;">
            An evening you'll never forget
          </h2>
          <div class="gold-rule"></div>
          <p style="font-size:0.875rem;color:#4a4540;line-height:1.8;">
            From intimate dinners beneath twinkling lights to grand celebrations in our restored barn, every evening here becomes a memory.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: The Gardens (Dark) -->
  <section style="background-color:#1a1714;padding:6rem 1.5rem;" aria-labelledby="gardens-heading">
    <div class="reveal-card" style="max-width:64rem;margin:0 auto;background-color:#242019;border-radius:1rem;overflow:hidden;box-shadow:0 25px 50px rgba(0,0,0,0.4);">
      <div class="card-inner">
        <img class="card-img"
          src="https://plus.unsplash.com/premium_photo-1673141390230-8b4a3c3152b1?q=80&w=1546&auto=format&fit=crop"
          alt="Lush garden wedding venue with beautiful floral arrangements"
        />
        <div class="card-text">
          <p style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.3em;color:#d4a853;margin-bottom:1rem;">03 · Gardens</p>
          <h2 id="gardens-heading" class="font-display" style="font-style:italic;font-size:clamp(1.75rem,3vw,2.75rem);color:#ffffff;line-height:1.2;margin-bottom:1rem;">
            Where nature sets the scene
          </h2>
          <div class="gold-rule"></div>
          <p style="font-size:0.875rem;color:#c8bdb6;line-height:1.8;">
            Wander through our curated gardens where every pathway leads to a picture-perfect moment waiting to be captured.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: The Experience (Light) -->
  <section style="background-color:#faf8f5;padding:6rem 1.5rem;" aria-labelledby="experience-heading">
    <div class="reveal-card" style="max-width:64rem;margin:0 auto;background-color:#ffffff;border-radius:1rem;overflow:hidden;box-shadow:0 25px 50px rgba(0,0,0,0.08);">
      <div class="card-inner reverse">
        <img class="card-img"
          src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=800"
          alt="Joyful wedding celebration moment with guests dancing"
        />
        <div class="card-text">
          <p style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.3em;color:#8a6d3b;margin-bottom:1rem;">04 · Experience</p>
          <h2 id="experience-heading" class="font-display" style="font-style:italic;font-size:clamp(1.75rem,3vw,2.75rem);color:#1a1714;line-height:1.2;margin-bottom:1rem;">
            Every detail, thoughtfully placed
          </h2>
          <div class="gold-rule"></div>
          <p style="font-size:0.875rem;color:#4a4540;line-height:1.8;">
            From the first consultation to your final farewell, our dedicated team ensures every moment reflects the story uniquely yours.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section style="background-color:#f9f0ec;padding:6rem 1.5rem;text-align:center;" aria-labelledby="cta-heading">
    <div style="max-width:40rem;margin:0 auto;">
      <h2 id="cta-heading" class="font-display" style="font-style:italic;font-size:clamp(2.5rem,6vw,4rem);color:#1a1714;line-height:1.2;margin-bottom:1.5rem;">
        Your story starts here.
      </h2>
      <p style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.25em;color:#6b5f58;margin-bottom:2.5rem;">
        Let us help you create something unforgettable
      </p>
      <button type="button" style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.15em;padding:1rem 2.5rem;border:1px solid #6b4f1a;color:#6b4f1a;background:transparent;cursor:pointer;">
        Begin Planning
      </button>
    </div>
  </section>

  <!-- Footer -->
  <footer style="position:relative;background-color:#1a1714;padding:5rem 1.5rem;overflow:hidden;">
    <div style="position:absolute;inset:0;z-index:0;" aria-hidden="true">
      <svg style="width:100%;height:100%;" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" viewBox="0 0 1200 400">
        <defs>
          <pattern id="ripples" x="0" y="0" width="400" height="400" patternUnits="userSpaceOnUse">
            <ellipse cx="200" cy="200" rx="40" ry="15" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
            <ellipse cx="200" cy="200" rx="80" ry="30" fill="none" stroke="rgba(255,255,255,0.025)" stroke-width="1"/>
            <ellipse cx="200" cy="200" rx="120" ry="45" fill="none" stroke="rgba(255,255,255,0.02)" stroke-width="1"/>
            <ellipse cx="200" cy="200" rx="160" ry="60" fill="none" stroke="rgba(255,255,255,0.015)" stroke-width="1"/>
            <ellipse cx="200" cy="200" rx="200" ry="75" fill="none" stroke="rgba(255,255,255,0.01)" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#ripples)"/>
      </svg>
    </div>
    <div style="position:absolute;top:0;left:0;right:0;height:1px;background:rgba(255,255,255,0.06);" aria-hidden="true"></div>
    <div style="position:relative;z-index:1;max-width:72rem;margin:0 auto;">
      <div class="footer-grid" style="display:flex;flex-direction:column;gap:3rem;">
        <div>
          <p class="font-display" style="font-style:italic;font-size:1.5rem;color:#ffffff;margin-bottom:0.75rem;">The White Birch</p>
          <p style="font-size:0.75rem;color:#a09890;line-height:1.8;">A sanctuary of romance in the heart of New Hampshire's White Mountains.</p>
        </div>
        <div>
          <p style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.2em;color:#8a7e78;margin-bottom:1rem;font-weight:600;">Quick Links</p>
          <nav style="display:flex;flex-direction:column;gap:0.75rem;" aria-label="Footer navigation">
            <a href="#" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.2em;color:#a09890;">Venue</a>
            <a href="#" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.2em;color:#a09890;">Weddings</a>
            <a href="#" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.2em;color:#a09890;">Gallery</a>
            <a href="#" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.2em;color:#a09890;">Contact</a>
          </nav>
        </div>
        <div>
          <p style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.2em;color:#8a7e78;margin-bottom:1rem;font-weight:600;">Get in Touch</p>
          <div style="display:flex;flex-direction:column;gap:0.4rem;">
            <p style="font-size:0.75rem;color:#a09890;">Littleton, NH 03561</p>
            <p style="font-size:0.75rem;color:#a09890;">hello@thewhitebirch.com</p>
            <p style="font-size:0.75rem;color:#a09890;">(603) 555-0147</p>
          </div>
        </div>
      </div>
      <div style="margin-top:4rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.06);text-align:center;">
        <p style="font-size:0.75rem;color:#a09890;text-transform:uppercase;letter-spacing:0.15em;">
          © 2026 The White Birch. All rights reserved. This is a portfolio demo.
        </p>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const revealCards = document.querySelectorAll('.reveal-card');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      revealCards.forEach(card => observer.observe(card));
    });
  </script>

</body>
</html>